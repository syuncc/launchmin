{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"types": ["node"],
		"skipLibCheck": true,
		"noEmit": false,
		"declaration": true,
		"sourceMap": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
